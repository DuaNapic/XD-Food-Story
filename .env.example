PORT=3001
SERVER_TIMEZONE=Asia/Shanghai

# Use one of these keys. LLM_API_KEY has the highest priority.
LLM_API_KEY=
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=

# Default points to DashScope OpenAI-compatible endpoint.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus
LLM_TIMEOUT_MS=20000
LLM_ENABLE_THINKING=false